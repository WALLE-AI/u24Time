# ============================================================
# U24Time Backend — Environment Variables Example
# Copy this to .env and fill in your values
# ============================================================

# --- Flask ---
FLASK_ENV=development
FLASK_DEBUG=true
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
SECRET_KEY=change-me-in-production

# --- Redis (required for Flask-SSE) ---
REDIS_URL=redis://127.0.0.1:6379/0

# --- PostgreSQL Database ---
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=u24time
DB_PASSWORD=your_db_password
DB_NAME=u24time
DB_ECHO=false

# ============================================================
# Data Source API Keys
# ============================================================

# --- ACLED (Free registration at https://acleddata.com) ---
ACLED_API_KEY=
ACLED_EMAIL=

# --- NASA FIRMS (Free at https://firms.modaps.eosdis.nasa.gov) ---
NASA_FIRMS_MAP_KEY=

# --- OpenSky Network (Free at https://opensky-network.org) ---
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# --- CoinGecko (free public api, no key needed for basic usage) ---
COINGECKO_API_KEY=

# --- EIA (US Energy, free at https://www.eia.gov/opendata) ---
EIA_API_KEY=

# ============================================================
# LLM Integration (Optional - for AI classification)
# ============================================================
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# ============================================================
# Crawler Settings
# ============================================================

# Social crawler cookie path (for Playwright)
CRAWLER_COOKIE_DIR=data/cookies

# Max concurrent RSS fetches
RSS_CONCURRENCY=10

# Request timeouts (seconds)
HTTP_TIMEOUT=15
RSS_TIMEOUT=20

# Rate limiting for social crawlers (seconds between requests)
SOCIAL_MIN_DELAY=2
SOCIAL_MAX_DELAY=5
